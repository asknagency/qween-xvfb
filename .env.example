# ── API (FastAPI, port 8000) ──────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=*

# ── App (Node.js renderer, port 3001) ────────────────────────────────────────
RENDERER_PORT=3001
RENDERER_URL=http://localhost:3001

# ── Xvfb / Chromium ───────────────────────────────────────────────────────────
# CHROMIUM_BIN is auto-detected from Playwright's install path if not set.
# Override only if you have a custom Chrome install.
# CHROMIUM_BIN=chromium
# CHROMIUM_BIN=/opt/pw-browsers/chromium-1194/chrome-linux/chrome
MAX_CONCURRENT_RENDERS=2
