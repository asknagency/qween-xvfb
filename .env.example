# ── API (FastAPI, port 8000) ──────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=*

# ── App (Node.js renderer, port 3001) ────────────────────────────────────────
RENDERER_PORT=3001
RENDERER_URL=http://localhost:3001

# ── Xvfb / Chromium ───────────────────────────────────────────────────────────
CHROMIUM_BIN=chromium
MAX_CONCURRENT_RENDERS=2
