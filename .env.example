# ── API (FastAPI) ─────────────────────────────────────────────────────────────
PORT=8000

# ── Node renderer (static file server for QweenRender.html + project ZIPs) ───
RENDERER_PORT=3001

# ── Public URLs ───────────────────────────────────────────────────────────────
# Locally these defaults just work. In proxied environments (CodeSandbox,
# Gitpod, GitHub Codespaces) each port gets its own public URL — set all
# three here so the API, renderer, and Chrome CDP can find each other.
#
# Example for CodeSandbox sandbox ID "hhx62k":
#   API_PUBLIC_URL=https://hhx62k-8000.csb.app
#   RENDERER_URL=https://hhx62k-3001.csb.app
#   CDP_URL=https://hhx62k-9222.csb.app
#
API_PUBLIC_URL=http://localhost:8000
RENDERER_URL=http://localhost:3001
CDP_URL=http://localhost:9222

# ── Chromium ──────────────────────────────────────────────────────────────────
# Auto-detected from Playwright's install path if not set.
# Override only if you have a custom Chrome binary.
# CHROMIUM_BIN=/opt/pw-browsers/chromium-1194/chrome-linux/chrome
MAX_CONCURRENT_RENDERS=2
